PORT=3000
NODE_ENV=production

# Shopify App Credentials (Client ID & Secret from Partners Dashboard)
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here
SHOPIFY_APP_SCOPES=write_draft_orders,read_draft_orders,write_customers,read_customers
SHOPIFY_APP_URL=https://your-app-name.onrender.com

# Payment Configuration
MIN_AMOUNT=1.00
MAX_AMOUNT=10000.00
CURRENCY_CODE=USD